{%- comment -%}
  Premium product card — Aura Riyah
  Usage: {% render 'product-card', card_product: product, show_wishlist_remove: false %}
{%- endcomment -%}
{%- liquid
  assign current_variant = card_product.selected_or_first_available_variant
  assign on_sale = false
  if card_product.compare_at_price > card_product.price
    assign on_sale = true
  endif
  assign placeholder_idx = card_product.id | modulo: 4 | plus: 1
  assign placeholder_name = 'product-apparel-' | append: placeholder_idx

  assign second_image = nil
  assign has_alt_image = false
  if card_product.media.size > 1
    for media in card_product.media
      if media.id != card_product.featured_media.id and media.media_type == 'image'
        assign second_image = media
        assign has_alt_image = true
        break
      endif
    endfor
  endif
-%}

<article class="product-card{% if has_alt_image %} product-card--has-alt-image{% endif %}" data-product-id="{{ card_product.id }}" data-product-handle="{{ card_product.handle }}">
  {%- if show_wishlist_remove -%}
    <button type="button" class="product-card__remove" data-wishlist-remove data-product-handle="{{ card_product.handle }}" aria-label="{{ 'sections.wishlist.remove' | t }}">
      {% render 'icon', icon: 'close', size: 18 %}
    </button>
  {%- endif -%}

  <div class="product-card__media">
    <a href="{{ card_product.url }}" class="product-card__media-link" aria-label="{{ card_product.title | escape }}">
      {%- if card_product.featured_media -%}
        {{ card_product.featured_media | image_url: width: 600 | image_tag:
          class: 'product-card__img product-card__img--primary',
          loading: 'lazy',
          widths: '300,400,600',
          sizes: '(min-width: 1200px) 33vw, (min-width: 768px) 50vw, 100vw',
          alt: card_product.featured_media.alt | default: card_product.title
        }}
        {%- if has_alt_image and second_image -%}
          {{ second_image | image_url: width: 600 | image_tag:
            class: 'product-card__img product-card__img--secondary',
            loading: 'lazy',
            alt: second_image.alt | default: card_product.title
          }}
        {%- endif -%}
      {%- else -%}
        <div class="product-card__placeholder-wrap">
          {{ placeholder_name | placeholder_svg_tag: 'product-card__placeholder-svg' }}
        </div>
      {%- endif -%}
    </a>

    <div class="product-card__badges">
      {%- if on_sale -%}
        <span class="badge badge--sale">
          -{{ card_product.compare_at_price | minus: card_product.price | times: 100 | divided_by: card_product.compare_at_price }}%
        </span>
      {%- endif -%}
      {%- if card_product.available == false -%}
        <span class="badge badge--stock">{{ 'products.product.sold_out' | t }}</span>
      {%- elsif current_variant.inventory_management == 'shopify' and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity < 5 -%}
        <span class="badge badge--stock">{{ 'products.product.low_stock' | t: count: current_variant.inventory_quantity }}</span>
      {%- endif -%}
    </div>

    <div class="product-card__actions">
      <button type="button" class="product-card__action-btn" data-wishlist-toggle data-product-handle="{{ card_product.handle }}" aria-label="{{ 'products.product.wishlist' | t }}">
        {% render 'icon', icon: 'heart', size: 18 %}
      </button>
      <button type="button" class="product-card__action-btn" data-quick-view data-product-handle="{{ card_product.handle }}" aria-label="{{ 'products.product.quick_view' | t }}">
        {% render 'icon', icon: 'eye', size: 18 %}
      </button>
    </div>

    {%- if card_product.available -%}
      <div class="product-card__quick-add">
        <button type="button" class="btn btn--primary btn--full btn--sm" data-add-to-cart data-variant-id="{{ current_variant.id }}" data-quantity="1">
          {{ 'products.product.quick_add' | t }}
        </button>
      </div>
    {%- endif -%}
  </div>

  <div class="product-card__body">
    {%- if card_product.vendor != blank -%}
      <span class="product-card__vendor">{{ card_product.vendor }}</span>
    {%- endif -%}

    <h3 class="product-card__title">
      <a href="{{ card_product.url }}">{{ card_product.title }}</a>
    </h3>

    {%- assign color_option = card_product.options_by_name['Color'] | default: card_product.options_by_name['Colour'] -%}
    {%- if color_option and color_option.values.size > 0 -%}
      <div class="product-card__swatches" role="list">
        {%- for value in color_option.values limit: 5 -%}
          <span class="product-card__swatch{% if forloop.first %} is-active{% endif %}" role="listitem" title="{{ value | escape }}" style="background-color: {{ value | handle }};"></span>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="product-card__price">
      <span class="product-card__price-current">{{ card_product.price | money }}</span>
      {%- if on_sale -%}
        <span class="product-card__price-compare">{{ card_product.compare_at_price | money }}</span>
      {%- endif -%}
    </div>
  </div>
</article>
