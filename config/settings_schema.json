[
  {
    "name": "theme_info",
    "theme_name": "Aura Riyah",
    "theme_version": "1.0.0",
    "theme_author": "Aura Riyah",
    "theme_documentation_url": "https://github.com/aurariyah/theme",
    "theme_support_url": "https://aurariyah.com/support"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#F8F6F3"
      },
      {
        "type": "color",
        "id": "color_background_secondary",
        "label": "Secondary background",
        "default": "#EFEBE6"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent (Maroon)",
        "default": "#6B1D3A"
      },
      {
        "type": "color",
        "id": "color_accent_hover",
        "label": "Accent hover",
        "default": "#8B2549"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text",
        "default": "#1A1A1A"
      },
      {
        "type": "color",
        "id": "color_text_muted",
        "label": "Muted text",
        "default": "#6B6B6B"
      },
      {
        "type": "color",
        "id": "color_gold",
        "label": "Champagne gold accent",
        "default": "#C9A962"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border",
        "default": "#E5E0DA"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "range",
        "id": "heading_scale",
        "min": 100,
        "max": 150,
        "step": 5,
        "unit": "%",
        "label": "Heading scale",
        "default": 100
      },
      {
        "type": "range",
        "id": "body_scale",
        "min": 100,
        "max": 130,
        "step": 5,
        "unit": "%",
        "label": "Body scale",
        "default": 100
      }
    ]
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 80,
        "max": 280,
        "step": 10,
        "unit": "px",
        "label": "Logo width",
        "default": 140
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "checkbox",
        "id": "cart_drawer_enabled",
        "label": "Enable cart drawer",
        "default": true
      },
      {
        "type": "number",
        "id": "free_shipping_threshold",
        "label": "Free shipping threshold (store currency)",
        "default": 200
      }
    ]
  },
  {
    "name": "Social",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "text",
        "id": "social_tiktok",
        "label": "TikTok URL"
      },
      {
        "type": "text",
        "id": "social_twitter",
        "label": "Twitter / X URL"
      }
    ]
  },
  {
    "name": "Trust & GCC",
    "settings": [
      {
        "type": "text",
        "id": "warranty_text",
        "label": "Default warranty text",
        "default": "2-Year Official Warranty"
      },
      {
        "type": "text",
        "id": "delivery_text",
        "label": "Default delivery estimate",
        "default": "Delivered in 1–3 business days across GCC"
      },
      {
        "type": "checkbox",
        "id": "show_installment_badges",
        "label": "Show installment payment badges",
        "default": true
      }
    ]
  }
]
