{%- if section.settings.show_section -%}
<section class="section section--tight section-flash-sale-wrap">
  <div class="container">
    <div class="flash-sale">
      <div class="flash-sale__inner">
        <div class="flash-sale__copy">
          {%- if section.settings.eyebrow != blank -%}
            <p class="flash-sale__eyebrow text-label">{{ section.settings.eyebrow }}</p>
          {%- endif -%}
          <h2 class="flash-sale__title h3">{{ section.settings.title }}</h2>
        </div>

        <div class="flash-sale__countdown" data-countdown data-end="{{ section.settings.end_date | default: '2026-12-31T23:59:59' }}">
          <p class="flash-sale__countdown-label">{{ 'sections.flash_sale.ends_in' | t }}</p>
          <div class="countdown">
            <div class="countdown__unit"><span class="countdown__value" data-days>00</span><span class="countdown__label">Days</span></div>
            <div class="countdown__unit"><span class="countdown__value" data-hours>00</span><span class="countdown__label">Hrs</span></div>
            <div class="countdown__unit"><span class="countdown__value" data-minutes>00</span><span class="countdown__label">Min</span></div>
            <div class="countdown__unit"><span class="countdown__value" data-seconds>00</span><span class="countdown__label">Sec</span></div>
          </div>
        </div>

        {%- if section.settings.collection != blank -%}
          <a href="{{ section.settings.collection.url }}" class="btn btn--ghost flash-sale__cta">{{ 'sections.flash_sale.shop_deals' | t }}</a>
        {%- else -%}
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--ghost flash-sale__cta">{{ 'sections.flash_sale.shop_deals' | t }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Flash sale countdown",
  "tag": "section",
  "class": "section-flash-sale",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show section", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Limited Time" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Flash Sale - Up to 40% Off" },
    { "type": "text", "id": "end_date", "label": "End date (ISO)", "default": "2026-12-31T23:59:59" },
    { "type": "collection", "id": "collection", "label": "Collection" }
  ],
  "presets": [{ "name": "Flash sale" }]
}
{% endschema %}
