<section class="section">
  <div class="container">
    {%- if section.settings.title != blank -%}
      <div class="section__header">
        <h2 class="h2">{{ section.settings.title }}</h2>
      </div>
    {%- endif -%}
    <div class="grid grid--3">
      {%- for block in section.blocks -%}
        {%- liquid
          assign cat_placeholder = 'collection-apparel-'
          assign cat_idx = forloop.index | modulo: 4
          if cat_idx == 0
            assign cat_idx = 4
          endif
          assign cat_placeholder = cat_placeholder | append: cat_idx
        -%}
        <a href="{{ block.settings.link | default: '#' }}" class="category-tile{% unless block.settings.image != blank %} category-tile--placeholder{% endunless %}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'category-tile__img', alt: block.settings.title }}
          {%- else -%}
            {% render 'placeholder-image', name: cat_placeholder, class: 'placeholder-image--category' %}
          {%- endif -%}
          <div class="category-tile__text">
            <p class="text-label category-tile__eyebrow">{{ block.settings.eyebrow }}</p>
            <h3 class="h4 category-tile__title">{{ block.settings.title }}</h3>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .category-tile {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--color-bg-secondary);
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    transition: transform var(--transition), box-shadow var(--transition);
  }
  .category-tile__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
  }
  .category-tile__text { position: relative; z-index: 1; }
  .category-tile__eyebrow { color: var(--color-white); opacity: 0.9; text-shadow: 0 1px 8px rgba(0,0,0,0.35); }
  .category-tile__title { color: var(--color-white); text-shadow: 0 1px 12px rgba(0,0,0,0.4); }
  .category-tile--placeholder .category-tile__eyebrow,
  .category-tile--placeholder .category-tile__title { color: var(--color-text); text-shadow: none; }
  .category-tile:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
</style>

{% schema %}
{
  "name": "Category tiles",
  "tag": "section",
  "class": "section-category-tiles",
  "settings": [
    { "type": "text", "id": "title", "label": "Section heading", "default": "Shop by Category" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Category",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Audio" },
        { "type": "text", "id": "title", "label": "Title", "default": "Headphones" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category tiles",
      "blocks": [
        { "type": "tile", "settings": { "eyebrow": "Audio", "title": "Headphones & Earbuds" } },
        { "type": "tile", "settings": { "eyebrow": "Wearables", "title": "Smartwatches" } },
        { "type": "tile", "settings": { "eyebrow": "Gaming", "title": "Gaming Gear" } }
      ]
    }
  ]
}
{% endschema %}
