<section class="section">
  <div class="container">
    {%- if section.settings.title != blank -%}
      <div class="section__header">
        <h2 class="h2">{{ section.settings.title }}</h2>
      </div>
    {%- endif -%}
    <div class="grid grid--3">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link }}" class="category-tile" {{ block.shopify_attributes }} style="position:relative;border-radius:var(--radius-xl);overflow:hidden;aspect-ratio:4/3;background:var(--color-bg-secondary);display:flex;align-items:flex-end;padding:1.5rem;border:1px solid var(--color-border);transition:transform var(--transition),box-shadow var(--transition)">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', style: 'position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.85', alt: block.settings.title }}
          {%- endif -%}
          <div style="position:relative;z-index:1">
            <p class="text-label" style="color:var(--color-white);opacity:0.9">{{ block.settings.eyebrow }}</p>
            <h3 class="h4" style="color:var(--color-white)">{{ block.settings.title }}</h3>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .category-tile:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
</style>

{% schema %}
{
  "name": "Category tiles",
  "tag": "section",
  "class": "section-category-tiles",
  "settings": [
    { "type": "text", "id": "title", "label": "Section heading", "default": "Shop by Category" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Category",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Audio" },
        { "type": "text", "id": "title", "label": "Title", "default": "Headphones" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category tiles",
      "blocks": [
        { "type": "tile", "settings": { "eyebrow": "Audio", "title": "Headphones & Earbuds" } },
        { "type": "tile", "settings": { "eyebrow": "Wearables", "title": "Smartwatches" } },
        { "type": "tile", "settings": { "eyebrow": "Gaming", "title": "Gaming Gear" } }
      ]
    }
  ]
}
{% endschema %}
