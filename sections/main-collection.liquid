<div class="container collection-layout">
  <aside class="collection-filters" id="CollectionFilters">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem">
      <h3 class="h4">{{ 'sections.collection.filters' | t }}</h3>
      <button type="button" data-filters-close class="header-icon-btn" style="display:none">{% render 'icon', icon: 'close' %}</button>
    </div>

    <form id="CollectionFiltersForm">
      {%- for filter in collection.filters -%}
        <div style="margin-bottom:1.5rem">
          <p class="text-label" style="margin-bottom:0.75rem">{{ filter.label }}</p>
          {%- case filter.type -%}
            {%- when 'list' -%}
              <ul>
                {%- for value in filter.values -%}
                  <li style="margin-bottom:0.5rem">
                    <label style="display:flex;align-items:center;gap:0.5rem;font-size:0.875rem;cursor:pointer">
                      <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}" {% if value.active %}checked{% endif %} {% if value.count == 0 and value.active == false %}disabled{% endif %}>
                      {{ value.label }} ({{ value.count }})
                    </label>
                  </li>
                {%- endfor -%}
              </ul>
            {%- when 'price_range' -%}
              <div style="display:flex;gap:0.5rem">
                <input type="number" name="{{ filter.min_value.param_name }}" placeholder="Min" value="{{ filter.min_value.value }}" style="width:100%;padding:0.5rem;border:1px solid var(--color-border);border-radius:8px">
                <input type="number" name="{{ filter.max_value.param_name }}" placeholder="Max" value="{{ filter.max_value.value }}" style="width:100%;padding:0.5rem;border:1px solid var(--color-border);border-radius:8px">
              </div>
          {%- endcase -%}
        </div>
      {%- endfor -%}
      <button type="submit" class="btn btn--primary btn--full">{{ 'sections.collection.apply' | t }}</button>
      <a href="{{ collection.url }}" class="btn btn--secondary btn--full" style="margin-top:0.5rem">{{ 'sections.collection.clear_filters' | t }}</a>
    </form>
  </aside>

  <div>
    {%- if collection.image -%}
      <div class="collection-banner">
        {{ collection.image | image_url: width: 1600 | image_tag: loading: 'eager', style: 'position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.4' }}
        <h1 class="collection-banner__title" style="position:relative;z-index:1">{{ collection.title }}</h1>
      </div>
    {%- else -%}
      <h1 class="h2" style="margin-bottom:var(--space-md)">{{ collection.title }}</h1>
    {%- endif -%}

    {%- if collection.description != blank -%}
      <p class="text-muted" style="margin-bottom:var(--space-lg);max-width:640px">{{ collection.description }}</p>
    {%- endif -%}

    <div class="collection-toolbar">
      <p class="text-muted">{{ 'sections.collection.products_count' | t: count: collection.products_count }}</p>
      <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap">
        <button type="button" class="btn btn--secondary btn--sm" data-filters-open style="display:none">{{ 'sections.collection.filters' | t }}</button>
        <div class="collection-view-toggle">
          <button type="button" class="header-icon-btn is-active" data-view-grid aria-label="{{ 'sections.collection.grid_view' | t }}">{% render 'icon', icon: 'grid', size: 18 %}</button>
          <button type="button" class="header-icon-btn" data-view-list aria-label="{{ 'sections.collection.list_view' | t }}">{% render 'icon', icon: 'menu', size: 18 %}</button>
        </div>
      </div>
    </div>

    {%- paginate collection.products by section.settings.products_per_page -%}
    <div class="grid grid--products collection-products" id="ProductGrid">
      {%- for product in collection.products -%}
        {% render 'product-card', card_product: product %}
      {%- else -%}
        <p class="text-muted">{{ 'general.search.no_results' | t }}</p>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav class="pagination" style="display:flex;justify-content:center;gap:1rem;margin-top:var(--space-lg)" aria-label="Pagination">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}" class="btn btn--secondary btn--sm">{{ 'general.pagination.previous' | t }}</a>
        {%- endif -%}
        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}" class="btn btn--primary btn--sm">{{ 'general.pagination.next' | t }}</a>
        {%- endif -%}
      </nav>
    {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "section-collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24,
      "label": "Products per page"
    }
  ]
}
{% endschema %}
