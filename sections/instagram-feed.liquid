<section class="section" style="background:var(--color-bg-secondary)">
  <div class="container">
    <div class="section__header">
      <div>
        <p class="text-label">{{ section.settings.eyebrow }}</p>
        <h2 class="h2">{{ section.settings.title }}</h2>
      </div>
      {%- if settings.social_instagram != blank -%}
        <a href="{{ settings.social_instagram }}" class="btn btn--secondary btn--sm" target="_blank" rel="noopener">@aurariyah</a>
      {%- endif -%}
    </div>
    <div class="grid grid--4" style="gap:0.5rem">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: settings.social_instagram }}" {{ block.shopify_attributes }} style="aspect-ratio:1;border-radius:var(--radius-md);overflow:hidden;display:block">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover' }}
          {%- else -%}
            <div class="skeleton" style="aspect-ratio:1"></div>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Social gallery",
  "settings": [
    { "type": "text", "id": "eyebrow", "default": "@aurariyah" },
    { "type": "text", "id": "title", "default": "Lifestyle & Community" }
  ],
  "blocks": [
    { "type": "image", "name": "Image", "settings": [
      { "type": "image_picker", "id": "image" },
      { "type": "url", "id": "link" }
    ]}
  ],
  "max_blocks": 8,
  "presets": [{ "name": "Social gallery", "blocks": [{ "type": "image" }, { "type": "image" }, { "type": "image" }, { "type": "image" }] }]
}
{% endschema %}
