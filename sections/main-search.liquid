<section class="section">
  <div class="container">
    <h1 class="h2" style="margin-bottom:var(--space-md)">{{ 'general.search.title' | t }}</h1>
    <form action="{{ routes.search_url }}" method="get" role="search" style="margin-bottom:var(--space-lg)">
      <input type="search" name="q" value="{{ search.terms | escape }}" class="search-modal__input" style="font-size:1.5rem" placeholder="{{ 'general.search.placeholder' | t }}">
    </form>

    {%- if search.performed -%}
      <p class="text-muted" style="margin-bottom:var(--space-md)">{{ search.results_count }} results</p>
      <div class="grid grid--products">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            {% render 'product-card', card_product: item %}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{ "name": "Search results", "tag": "section" }
{% endschema %}
