<section class="hero-slider" id="HeroSlider" aria-label="Hero">
  {%- for block in section.blocks -%}
    <div class="hero-slide{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }} data-slide="{{ forloop.index0 }}">
      <div class="hero-slide__content">
        {%- if block.settings.eyebrow != blank -%}
          <p class="hero-slide__eyebrow">{{ block.settings.eyebrow }}</p>
        {%- endif -%}
        <h1 class="hero-slide__title">{{ block.settings.heading }}</h1>
        {%- if block.settings.subheading != blank -%}
          <p class="hero-slide__subtitle">{{ block.settings.subheading }}</p>
        {%- endif -%}
        <div class="hero-slide__actions">
          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.button_link }}" class="btn btn--primary btn--lg">{{ block.settings.button_label }}</a>
          {%- endif -%}
          {%- if block.settings.button_secondary_label != blank -%}
            <a href="{{ block.settings.button_secondary_link }}" class="btn btn--secondary btn--lg">{{ block.settings.button_secondary_label }}</a>
          {%- endif -%}
        </div>
      </div>
      <div class="hero-slide__visual">
        <div class="hero-slide__frame">
          {%- if forloop.first -%}
            {%- assign hero_img_loading = 'eager' -%}
          {%- else -%}
            {%- assign hero_img_loading = 'lazy' -%}
          {%- endif -%}
          {%- comment -%} Layer 1: lifestyle / texture fills the card {%- endcomment -%}
          <div class="hero-slide__frame-media">
            {%- if block.settings.background_image != blank -%}
              {{ block.settings.background_image | image_url: width: 1200 | image_tag:
                class: 'hero-slide__frame-bg',
                loading: hero_img_loading,
                widths: '480,720,960,1200',
                sizes: '(min-width: 768px) 480px, 80vw',
                alt: ''
              }}
            {%- else -%}
              <span class="hero-slide__frame-bg hero-slide__frame-bg--default" aria-hidden="true"></span>
            {%- endif -%}
          </div>

          {%- comment -%} Layer 2: transparent product floats above the card {%- endcomment -%}
          {%- if block.settings.product_image != blank -%}
            <div class="hero-slide__frame-float">
              {{ block.settings.product_image | image_url: width: 1600 | image_tag:
                class: 'hero-slide__product-float',
                loading: hero_img_loading,
                widths: '400,600,800,1200,1600',
                sizes: '(min-width: 768px) 420px, 70vw',
                alt: block.settings.heading
              }}
            </div>
          {%- elsif block.settings.background_image == blank -%}
            {%- liquid
              assign hero_idx = forloop.index | modulo: 4
              if hero_idx == 0
                assign hero_idx = 4
              endif
              assign hero_placeholder = 'product-apparel-' | append: hero_idx
            -%}
            <div class="hero-slide__frame-float">
              {% render 'placeholder-image', name: hero_placeholder, class: 'hero-slide__product-placeholder' %}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endfor -%}

  {%- if section.blocks.size > 1 -%}
    <div class="hero-slider__nav" role="tablist">
      {%- for block in section.blocks -%}
        <button type="button" class="hero-slider__dot{% if forloop.first %} is-active{% endif %}" aria-label="Slide {{ forloop.index }}" role="tab"></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero slider",
  "tag": "section",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "New Arrival" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Sound. Elevated." },
        { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Premium audio engineered for the Gulf." },
        { "type": "text", "id": "button_label", "label": "Primary button", "default": "Shop Now" },
        { "type": "url", "id": "button_link", "label": "Primary link" },
        { "type": "text", "id": "button_secondary_label", "label": "Secondary button", "default": "Explore Collection" },
        { "type": "url", "id": "button_secondary_link", "label": "Secondary link" },
        {
          "type": "paragraph",
          "content": "Card background: lifestyle photo inside the frame. Recommended 1920 x 1920 px (1:1), JPG or WebP, fills the card with cover crop."
        },
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Card background image"
        },
        {
          "type": "paragraph",
          "content": "Floating product: transparent PNG on top of the card. Recommended 1600 x 1600 px (or 1400 x 1600 for tall products). Leave empty for background-only slides."
        },
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Floating product image (PNG)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero slider",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Premium Audio",
            "heading": "Sound. Elevated.",
            "subheading": "Studio-grade wireless headphones crafted for discerning listeners across the GCC.",
            "button_label": "Shop Now",
            "button_secondary_label": "Explore Collection"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Smart Living",
            "heading": "Future on Your Wrist.",
            "subheading": "Next-generation smartwatches with Gulf-ready precision and style.",
            "button_label": "Discover Watches"
          }
        }
      ]
    }
  ]
}
{% endschema %}
