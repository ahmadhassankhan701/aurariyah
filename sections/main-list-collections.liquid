<section class="section">
  <div class="container">
    <h1 class="h2" style="margin-bottom:var(--space-lg)">Collections</h1>
    <div class="grid grid--3">
      {%- for collection in collections -%}
        <a href="{{ collection.url }}" class="category-tile" style="position:relative;border-radius:var(--radius-xl);overflow:hidden;aspect-ratio:4/3;background:var(--color-bg-secondary);display:flex;align-items:flex-end;padding:1.5rem;border:1px solid var(--color-border)">
          {%- if collection.featured_image -%}
            {{ collection.featured_image | image_url: width: 600 | image_tag: style: 'position:absolute;inset:0;width:100%;height:100%;object-fit:cover', loading: 'lazy' }}
          {%- endif -%}
          <h2 class="h4" style="position:relative;z-index:1;color:var(--color-text)">{{ collection.title }}</h2>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{ "name": "Collections list", "tag": "section" }
{% endschema %}
