<section class="section" data-wishlist-page>
  <div class="container">
    <h1 class="h2" style="margin-bottom:var(--space-lg)">{{ 'sections.header.wishlist' | t }}</h1>
    <p class="text-muted" data-wishlist-empty>{{ 'sections.wishlist.empty' | t }}</p>
    <div id="WishlistGrid" class="grid grid--products" data-wishlist-grid></div>
  </div>
</section>

{% schema %}
{
  "name": "Wishlist",
  "tag": "section",
  "class": "section-wishlist"
}
{% endschema %}
