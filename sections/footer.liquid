<footer class="site-footer">
  <div class="container">
    <div class="site-footer__grid">
      <div>
        <span class="site-header__logo-text" style="color:#fff;font-size:1.5rem">Aura Riyah</span>
        <p style="margin-top:1rem;max-width:320px;font-size:0.875rem;opacity:0.7">
          {{ section.settings.about_text }}
        </p>
        {%- if section.settings.show_newsletter -%}
          <div style="margin-top:1.5rem">
            <p class="text-label" style="color:var(--color-gold);margin-bottom:0.5rem">{{ 'sections.footer.newsletter_title' | t }}</p>
            {% form 'customer', class: 'newsletter-form' %}
              <div style="display:flex;gap:0.5rem">
                <input type="email" name="contact[email]" placeholder="{{ 'sections.footer.newsletter_placeholder' | t }}" required style="flex:1;padding:0.75rem 1rem;border-radius:8px;border:none;background:rgba(255,255,255,0.1);color:#fff">
                <button type="submit" class="btn btn--primary btn--sm">{{ 'sections.footer.subscribe' | t }}</button>
              </div>
            {% endform %}
          </div>
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'link_list' -%}
          <div {{ block.shopify_attributes }}>
            <h4 style="color:#fff;margin-bottom:1rem;font-size:0.875rem">{{ block.settings.title }}</h4>
            <ul>
              {%- for link in block.settings.menu.links -%}
                <li style="margin-bottom:0.5rem"><a href="{{ link.url }}" style="font-size:0.875rem;opacity:0.7">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div style="margin-top:3rem;padding-top:1.5rem;border-top:1px solid rgba(255,255,255,0.1);display:flex;justify-content:space-between;flex-wrap:wrap;gap:1rem;font-size:0.75rem;opacity:0.6">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'sections.footer.rights' | t }}</p>
      <div style="display:flex;gap:1rem">
        {%- if settings.social_instagram != blank -%}<a href="{{ settings.social_instagram }}">Instagram</a>{%- endif -%}
        {%- if settings.social_tiktok != blank -%}<a href="{{ settings.social_tiktok }}">TikTok</a>{%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "section-footer",
  "max_blocks": 4,
  "settings": [
    {
      "type": "textarea",
      "id": "about_text",
      "label": "About text",
      "default": "Premium accessories and smart gadgets for the modern Gulf lifestyle."
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "link_list", "settings": { "title": "Shop" } },
      { "type": "link_list", "settings": { "title": "Support" } },
      { "type": "link_list", "settings": { "title": "Company" } }
    ]
  }
}
{% endschema %}
